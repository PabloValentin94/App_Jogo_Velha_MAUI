<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="App_Jogo_Velha_MAUI.MainPage">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
            <GradientStop Color="#845ec2" Offset="0.1"/>
            <GradientStop Color="#009efa" Offset="0.35"/>
            <GradientStop Color="#00d2fc" Offset="0.7"/>
            <GradientStop Color="#4ffbdf" Offset="0.9"/>
        </LinearGradientBrush>
    </ContentPage.Background>
    
    <ContentPage.Resources>
        <Style TargetType="Button" x:Key="btn_game">
            <Setter Property="FontSize" Value="Large"/>
            <Setter Property="TextColor" Value="#FFFFFF"/>
            <Setter Property="BackgroundColor" Value="#202020"/>
        </Style>
    </ContentPage.Resources>
    
    <ContentPage.Content>
        <ScrollView>
            <Grid
                x:Name="grid_game"
                ColumnDefinitions="*,*,*,*"
                RowDefinitions="Auto,*,*,*,*,Auto"
                ColumnSpacing="15"
                RowSpacing="15"
                Padding="15"
            >
                <!-- Título -->

                <Label
                    x:Name="lbl_title"
                    Grid.Column="0"
                    Grid.Row="0"
                    Text="JOGO DA VELHA"
                    FontSize="Title"
                    FontAttributes="Bold"
                    TextColor="#000000"
                    HorizontalTextAlignment="Center"
                />
                
                <!-- Opções -->

                <Button
                    StyleId="btn_game"
                    Grid.Column="0"
                    Grid.Row="1"
                    Style="{ StaticResource btn_game }"
                    Clicked="btn_game_Clicked"
                />

                <Button
                    StyleId="btn_game"
                    Grid.Column="1"
                    Grid.Row="1"
                    Style="{ StaticResource btn_game }"
                    Clicked="btn_game_Clicked"
                />

                <Button
                    StyleId="btn_game"
                    Grid.Column="2"
                    Grid.Row="1"
                    Style="{ StaticResource btn_game }"
                    Clicked="btn_game_Clicked"
                />

                <Button
                    StyleId="btn_game"
                    Grid.Column="3"
                    Grid.Row="1"
                    Style="{ StaticResource btn_game }"
                    Clicked="btn_game_Clicked"
                />

                <Button
                    StyleId="btn_game"
                    Grid.Column="0"
                    Grid.Row="2"
                    Style="{ StaticResource btn_game }"
                    Clicked="btn_game_Clicked"
                />

                <Button
                    StyleId="btn_game"
                    Grid.Column="1"
                    Grid.Row="2"
                    Style="{ StaticResource btn_game }"
                    Clicked="btn_game_Clicked"
                />

                <Button
                    StyleId="btn_game"
                    Grid.Column="2"
                    Grid.Row="2"
                    Style="{ StaticResource btn_game }"
                    Clicked="btn_game_Clicked"
                />

                <Button
                    StyleId="btn_game"
                    Grid.Column="3"
                    Grid.Row="2"
                    Style="{ StaticResource btn_game }"
                    Clicked="btn_game_Clicked"
                />

                <Button
                    StyleId="btn_game"
                    Grid.Column="0"
                    Grid.Row="3"
                    Style="{ StaticResource btn_game }"
                    Clicked="btn_game_Clicked"
                />

                <Button
                    StyleId="btn_game"
                    Grid.Column="1"
                    Grid.Row="3"
                    Style="{ StaticResource btn_game }"
                    Clicked="btn_game_Clicked"
                />

                <Button
                    StyleId="btn_game"
                    Grid.Column="2"
                    Grid.Row="3"
                    Style="{ StaticResource btn_game }"
                    Clicked="btn_game_Clicked"
                />

                <Button
                    StyleId="btn_game"
                    Grid.Column="3"
                    Grid.Row="3"
                    Style="{ StaticResource btn_game }"
                    Clicked="btn_game_Clicked"
                />

                <Button
                    StyleId="btn_game"
                    Grid.Column="0"
                    Grid.Row="4"
                    Style="{ StaticResource btn_game }"
                    Clicked="btn_game_Clicked"
                />

                <Button
                    StyleId="btn_game"
                    Grid.Column="1"
                    Grid.Row="4"
                    Style="{ StaticResource btn_game }"
                    Clicked="btn_game_Clicked"
                />

                <Button
                    StyleId="btn_game"
                    Grid.Column="2"
                    Grid.Row="4"
                    Style="{ StaticResource btn_game }"
                    Clicked="btn_game_Clicked"
                />

                <Button
                    StyleId="btn_game"
                    Grid.Column="3"
                    Grid.Row="4"
                    Style="{ StaticResource btn_game }"
                    Clicked="btn_game_Clicked"
                />

                <!-- Botão de Reset -->

                <Button
                    x:Name="btn_reset"
                    Grid.Column="0"
                    Grid.Row="5"
                    Grid.ColumnSpan="4"
                    Text="Reiniciar"
                    FontAttributes="Bold"
                    TextColor="#FFFFFF"
                    BackgroundColor="#000000"
                    Clicked="btn_reset_Clicked"
                />
            </Grid>
        </ScrollView>
    </ContentPage.Content>

</ContentPage>
